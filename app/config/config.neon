#
# SECURITY WARNING: it is CRITICAL that this file & directory are NOT accessible directly via a web browser!
#
# If you don't protect this directory from direct web access, anybody will be able to see your passwords.
# https://doc.nette.org/en/security-warning
#
php:
	date.timezone: Europe/Prague

http:
  forceHttps: true

session:
	autoStart: smart
	expiration: 30 days

application:
	errorPresenter: Error
	mapping: App\Presentation\*\**Presenter
	scanComposer: false

extensions:
	replicator: Kdyby\Replicator\DI\ReplicatorExtension

services:
	# Autowired by type - these have no other services depending on a *specific*
	# instance, so an explicit factory expression would just be noise. Without an
	# entry here, the DI container can't autowire them into a presenter constructor
	# at all (it only searches *registered* services; the test suite never caught
	# this because it constructs presenters directly with `new`, bypassing the
	# container entirely).
	- App\Model\Calendar\CalendarSearchFacade
	- App\Model\Export\EmptyDayFiller
	- App\Forms\SearchFormFactory
	- App\Forms\ExportFormFactory

	routerFactory: App\Core\RouterFactory
	router: @routerFactory::createRouter()

	oauthAuthenticator: App\Model\Google\OAuthAuthenticator(@googleClient)

	googleClientFactory: App\Model\Google\ClientFactory(%env.GOOGLE_CLIENT_ID%, %env.GOOGLE_CLIENT_SECRET%, %env.GOOGLE_REDIRECT_URI%)
	googleClient: @googleClientFactory::create()
	calendarApi: Google\Service\Calendar(@googleClient)
	google: App\Model\Google\GoogleCalendarService(@calendarApi)
