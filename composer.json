{
	"name": "tulinkry/dutymanager",
	"description": "DutyManager - turns a Google Calendar into a duty roster with pay calculation",
	"type": "project",
	"license": "BSD-3-Clause",
	"require": {
		"php": "^8.2",
		"nette/application": "^3.2",
		"nette/bootstrap": "^3.2",
		"nette/di": "^3.2",
		"nette/forms": "^3.2",
		"nette/http": "^3.3",
		"nette/security": "^3.2",
		"nette/utils": "^4.0",
		"latte/latte": "^3.0",
		"tracy/tracy": "^2.10",
		"google/apiclient": "^2.19",
		"kdyby/forms-replicator": "^3.0",
		"cweagans/composer-patches": "^1.7"
	},
	"require-dev": {
		"nette/tester": "^2.5"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"cweagans/composer-patches": true
		}
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"Google\\Task\\Composer::cleanup"
		],
		"post-update-cmd": [
			"Google\\Task\\Composer::cleanup"
		]
	},
	"extra": {
		"google/apiclient-services": [
			"Calendar",
			"Oauth2"
		],
		"patches": {
			"kdyby/forms-replicator": {
				"current Nette's monitor() only invokes its own callback (no longer calls attached()), so Container's row-reconstruction-from-POST never ran; Container::remove()/addRemoveOnClick() also use the removed $component->parent magic property - all unreported upstream, see https://github.com/Kdyby/FormsReplicator": "patches/kdyby-replicator-monitor-callback.patch"
			}
		}
	}
}
